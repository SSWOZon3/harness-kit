{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@harnesskit/core": ["packages/core/src/index.ts"],
      "@harnesskit/shared": ["packages/shared/src/index.ts"]
    },
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}
